{
  "name": "care-competencies-api",
  "version": "0.1.0",
  "private": true,
  "description": "CareCompetencies — Express/SQL Server API",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:setup": "ts-node src/db-setup.ts",
    "db:drop": "ts-node src/db-drop.ts",
    "db:reset": "ts-node src/db-drop.ts && ts-node src/db-setup.ts && ts-node src/seed.ts",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@types/mssql": "^9.1.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
