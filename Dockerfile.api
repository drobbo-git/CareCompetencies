FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY api/package*.json ./
RUN npm ci --omit=dev

# Copy API source and build
COPY api/ ./
RUN npm run build

# Copy seed data alongside the compiled output so seed.ts can find it
# Path matches: path.resolve(__dirname, '../../etl/data/...') from dist/
COPY etl/data/ /etl/data/

EXPOSE 3001
CMD ["node", "dist/index.js"]
